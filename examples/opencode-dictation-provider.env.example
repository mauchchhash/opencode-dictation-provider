# Copy to ~/.config/opencode-dictation-provider/env, then replace both secrets.
# Generate each secret with: openssl rand -hex 32
DICTATION_API_KEY=replace-with-a-random-adapter-api-key
OPENCODE_SERVER_USERNAME=opencode
OPENCODE_SERVER_PASSWORD=replace-with-a-random-opencode-server-password

# Absolute path to OpenCode when it is not in the systemd user-service PATH.
# Set to the result of: command -v opencode
OPENCODE_BIN=opencode
MODELS_COMMAND_TIMEOUT_MS=10000

# Bind both services to loopback only. Do not expose either service publicly.
HOST=127.0.0.1
PORT=11435
OPENCODE_URL=http://127.0.0.1:4096
OPENCODE_AGENT=dictation-cleaner

# Set true only when journal entries may contain dictated text.
DICTATION_DEBUG=false
REQUEST_TIMEOUT_MS=30000
MAX_INPUT_CHARS=20000
